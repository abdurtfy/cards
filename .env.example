# ─────────────────────────────────────────────────────────────
# carddesign.skin — environment variables
# Copy to `.env` for local dev, or paste into Vercel → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=production

# Admin dashboard
ADMIN_PASSWORD=change_this_password

# Vercel KV / Upstash Redis (REQUIRED on Vercel for orders + product edits to persist)
# Vercel auto-populates these when you add the Vercel KV (or Upstash) integration.
KV_REST_API_URL=https://your-kv-endpoint.upstash.io
KV_REST_API_TOKEN=your_kv_rest_token

# Razorpay (payments)
RAZORPAY_KEY_ID=rzp_live_or_test_key_id
RAZORPAY_KEY_SECRET=razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=change_this_webhook_secret

# Shiprocket (shipping)
SHIPROCKET_EMAIL=shiprocket_login_email
SHIPROCKET_PASSWORD=shiprocket_password
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_WEBHOOK_TOKEN=change_this_shiprocket_token

# Customer emails — use either Resend OR SMTP (Resend takes priority)
RESEND_API_KEY=resend_api_key
EMAIL_FROM=orders@carddesign.skin
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=your_email@gmail.com
SMTP_PASS=gmail_app_password
